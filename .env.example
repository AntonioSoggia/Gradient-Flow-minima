# =============================================================================
# Gradient Flow Configuration
# =============================================================================
# Copy this file to .env and modify as needed
# Do not commit .env to version control

# =============================================================================
# Gradient Descent Parameters
# =============================================================================
ETA=1e-6
STEPS=10000
TOL=1e-5
N_POINTS=10
E_RANGE_MIN=0.5
E_RANGE_MAX=0.6
D_RANGE_MIN=0.5
D_RANGE_MAX=0.6

# =============================================================================
# Problem Parameters
# =============================================================================
SIGMA2=0
GRAD_TYPE=combined
USE_1D=False
W0=6
W0_EVEN=5
W0_ODD=6
SUBS=0
FULL_TRAJECTORY=True

# =============================================================================
# File Paths
# =============================================================================
# Output directory for results
OUTPUT_DIR=./outputs
CHECKPOINT_INTERVAL=5000

# Sigma2 range for GF_res.py
SIGMA2_START=1
SIGMA2_END=3

# =============================================================================
# Plot Configuration
# =============================================================================
PLOT_LEN_POINTS=200
PLOT_XLIM_MIN=0
PLOT_XLIM_MAX=7
PLOT_YLIM_MIN=0
PLOT_YLIM_MAX=2
PLOT_FILENAME=GradientFlow_det.pdf

# =============================================================================
# Parallel Processing
# =============================================================================
# Number of CPU workers (0 = auto-detect)
NUM_WORKERS=0
